rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'npZcgEF0SWPDJnrLvAlPOi8H8RQ2';
    }
    match /orders/{doc} {
      allow create: if request.resource.data.keys().hasAll(['cart', 'name', 'phone', 'address'])
                      && request.resource.data.cart is list
                      && request.resource.data.cart.size() > 0;
      allow read, update, delete: if request.auth != null && request.auth.uid == 'npZcgEF0SWPDJnrLvAlPOi8H8RQ2';
    }
    match /users/{doc} {
      allow read: if request.auth != null && doc == request.auth.uid;
      allow write: if request.auth != null && doc == request.auth.uid;
    }
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'npZcgEF0SWPDJnrLvAlPOi8H8RQ2';
    }
  }
}
