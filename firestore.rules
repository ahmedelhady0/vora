rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // المنتجات — أي حد يقرا، بس المسؤول (المسجل دخوله) يكتب
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // الطلبات — أي حد مسجل ينشئ طلب، المسؤول بس يشوف ويعدل
    match /orders/{doc} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['cart', 'name', 'phone', 'address'])
        && request.resource.data.cart is list
        && request.resource.data.cart.size() > 0;
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    // المستخدمين — كل واحد يقرا ويكتب بياناته بس
    match /users/{doc} {
      allow read: if request.auth != null && request.auth.uid == doc;
      allow write: if request.auth != null && request.auth.uid == doc;
    }

    // الإعدادات — أي حد يقرا، المسؤول بس يكتب
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }
  }
}
